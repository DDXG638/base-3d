// ============================================================
// 顶点着色器 — 粒子波浪效果
// 执行次数 = 粒子数量（6400 次），每个粒子执行一次
//
// Three.js 自动注入的变量（无需声明）：
//   position  — 当前顶点的局部坐标 (vec3)
//   projectionMatrix — 投影矩阵 (mat4)
//   modelViewMatrix  — 模型视图矩阵 (mat4)
// ============================================================

// 输出给片元着色器的变量，光栅化时会被插值
varying vec3 vColor;   // 该粒子的颜色
varying float vAlpha;  // 该粒子的透明度

// 从 JS 传入的 uniform：着色器运行时间
uniform float uTime;

// 伪随机函数 — 输入一个数，输出 0~1 之间看起来「随机」的值
// 原理：sin 对大幅值变化极其敏感，取小数部分得到伪随机
float hash(float n) {
  // sin(n) 的结果在 [-1, 1]，乘以大数后取小数部分 ≈ 0~1 的伪随机
  return fract(sin(n) * 43758.5453123);
}

void main() {
  // 拿到当前顶点的原始位置（Three.js 自动注入的 position）
  vec3 pos = position;

  // ---- 1. 计算每个粒子的独特参数 ----
  // gl_VertexID 是当前顶点的索引（0, 1, 2, ... 6399）
  // 用它作为种子，让每个粒子有不同的相位和频率
  float id = float(gl_VertexID);

  // phase ：该粒子的初始相位（0 ~ 2π），决定「从什么地方开始振荡」
  float phase = hash(id * 0.1) * 6.28;

  // freq ：该粒子的振荡频率（0.5 ~ 2.5），决定「振荡多快」
  // 每个粒子频率不同，产生错落感
  float freq = hash(id * 0.3) * 2.0 + 0.5;

  // ---- 2. 计算波浪偏移 ----
  // dist ：该粒子到原点的水平距离
  float dist = length(pos.xz);

  // 主波浪 — 以原点为中心的同心圆波
  // sin(距离 × 2.5 - 时间 × 频率 + 相位) × 振幅 0.8
  // 距离越大 → 越外圈 → 相位越靠前（外圈先动）
  float wave = sin(dist * 2.5 - uTime * freq + phase) * 0.8;

  // 叠加波浪 — 基于 X 位置的余弦波，增加复杂性
  // 主波 + 次波 = 更自然的水面感
  wave += cos(pos.x * 3.0 + uTime * 1.3 + phase) * 0.3;

  // 把波浪偏移应用到 Y 轴（上下浮动）
  pos.y += wave;

  // ---- 3. 根据高度计算颜色 ----
  // t ：将 wave 值归一化到 0~1
  // wave 范围大约是 [-1.1, 1.1]（sin ±0.8 + cos ±0.3）
  // +1.1 后变 [0, 2.2]，再 /2.2 变 [0, 1]
  float t = (wave + 1.1) / 2.2;

  // mix(a, b, t) ：线性插值，t=0 取 a，t=1 取 b
  // 波谷(t≈0) 蓝色 → vColor = (0.1, 0.4, 0.9)
  // 波峰(t≈1) 粉色 → vColor = (0.9, 0.3, 0.6)
  vColor = mix(
    vec3(0.1, 0.4, 0.9),   // 低位颜色：深蓝
    vec3(0.9, 0.3, 0.6),   // 高位颜色：玫红
    t
  );

  // ---- 4. 透明度 — 波峰更亮 ----
  // t=0(谷底) → alpha=0.4（半透明），t=1(峰顶) → alpha=1.0（不透明）
  vAlpha = 0.4 + t * 0.6;

  // ---- 5. 粒子大小 — 波峰更大 ----
  // 基础大小 6 像素，波峰额外 +2，波谷额外 -2
  gl_PointSize = 6.0 + wave * 2.0;

  // ---- 6. 必须输出：变换后的裁剪空间坐标 ----
  // MVP 变换：局部坐标 → 裁剪空间坐标
  gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
}
