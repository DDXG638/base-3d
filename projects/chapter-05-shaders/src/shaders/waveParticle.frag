// ============================================================
// 片元着色器 — 圆形粒子渲染
// 执行次数 = 所有粒子在屏幕上覆盖的像素总量
//
// 每个粒子是一个正方形方块（由 gl_PointSize 决定大小），
// 本着色器在这个方块内画圆，圆外丢弃。
// ============================================================

// 从顶点着色器传来（已通过光栅化插值）
varying vec3 vColor;   // 该片元所在粒子的颜色
varying float vAlpha;  // 该片元所在粒子的透明度

void main() {
  // ---- 1. 计算当前片元到粒子中心的距离 ----
  // gl_PointCoord ：当前片元在点精灵中的坐标，范围 [0, 1]×[0, 1]
  //
  //   (0,1) ─────────── (1,1)
  //     │      ·中心    │    ·中心 = (0.5, 0.5)
  //     │    (0.5,0.5)  │
  //   (0,0) ─────────── (1,0)
  //
  // length(gl_PointCoord - 0.5) 就是当前像素到中心的距离
  float dist = length(gl_PointCoord - vec2(0.5));

  // ---- 2. 丢弃圆外的片元 ----
  // 距离 > 0.5 的像素在方框内但在圆外，直接丢弃不渲染
  // 这样就画出了圆形而不是方形
  // discard 是 GLSL 关键字，跳过当前片元，不写入颜色缓冲
  if (dist > 0.5) discard;

  // ---- 3. 圆形内部：中心亮、边缘暗的渐变 ----
  // smoothstep(0.0, 0.5, dist) 的作用：
  //   dist=0(中心) → smoothstep 输出 0
  //   dist=0.25     → smoothstep 输出 0.5
  //   dist=0.5(边缘) → smoothstep 输出 1
  //   过渡曲线是平滑的 S 形（Hermite 插值）
  //
  // 1.0 - smoothstep = 中心 1.0 → 边缘 0.0 的衰减
  // 效果：粒子中心不透明，越靠近边缘越透明
  float alpha = 1.0 - smoothstep(0.0, 0.5, dist);

  // 叠加上顶点传来的透明系数（波峰亮、波谷暗）
  alpha *= vAlpha;

  // ---- 4. 输出最终颜色 ----
  // vec4(r, g, b, a)
  //   rgb = 顶点传来的颜色（蓝→粉渐变）
  //   a   = 计算出的透明度
  gl_FragColor = vec4(vColor, alpha);
}
